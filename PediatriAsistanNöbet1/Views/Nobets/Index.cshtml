@model IEnumerable<PediatriAsistanNöbet1.ViewModels.NobetViewModel>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Yeni Nöbet Oluştur", "Create")
</p>
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.AsistanAdiSoyadi)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.BolumAdi)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.NobetTarihi)
        </th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.AsistanAdiSoyadi)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.BolumAdi)
            </td>
            <td>
                @item.NobetTarihi.ToString("dd.MM.yyyy")
            </td>
            <td>
                @Html.ActionLink("Güncelle", "Edit", new { id = item.NobetID }) |
                @Html.ActionLink("Sil", "Delete", new { id = item.NobetID })
            </td>
        </tr>
    }

</table>
