@model IEnumerable<PediatriAsistanNöbet1.Models.Model.Bolum>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@*<p>
    @Html.ActionLink("Yeni Ekle", "Create")
</p>*@
<table class="table">
    <tr>
        <th>
            @Html.DisplayNameFor(model => model.BolumAdi)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.HastaSayisi)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.BosYatakSayisi)
        </th>
        <th>
            @Html.DisplayNameFor(model => model.Aciklama)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.BolumAdi)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.HastaSayisi)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.BosYatakSayisi)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Aciklama)
        </td>
        <td>
            @Html.ActionLink("Güncelle", "Edit", new { id=item.BolumID })
        </td>
    </tr>
}

</table>
