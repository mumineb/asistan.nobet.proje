@model PediatriAsistanNöbet1.Models.Model.Randevu

@{
    ViewBag.Title = "Randevu Al";
    Layout = "~/Views/Shared/_SiteLayout.cshtml";
}


<h2>Randevu Al</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="form-horizontal">
        <h4>Randevu</h4>
        <hr />
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })

        <div class="form-group">
            @Html.LabelFor(model => model.AsistanID, "Asistan", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("AsistanID", null, "Lütfen bir asistan seçin", new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.AsistanID, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(model => model.MusaitlikID, "Müsaitlik", htmlAttributes: new { @class = "control-label col-md-2" })
            <div class="col-md-10">
                @Html.DropDownList("MusaitlikID", null, "Lütfen bir müsaitlik seçin", new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.MusaitlikID, "", new { @class = "text-danger" })
            </div>
        </div>

        <div class="form-group">
            <div class="col-md-offset-2 col-md-10">
                <input type="submit" value="Randevu Al" class="btn btn-primary" />
            </div>
        </div>
    </div>
}

<div>
    @Html.ActionLink("Back to List", "Index")
</div>
