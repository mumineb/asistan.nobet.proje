
@{
    ViewBag.Title = "Admin Ana Sayfa";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@{
    ViewBag.Title = "Admin Paneli - Ana Sayfa";
}

<div class="container">
    <h1 class="mt-4">Admin Paneli</h1>
    <p>Hoş geldiniz! Bu panelden sistem yönetimi işlemlerini gerçekleştirebilirsiniz.</p>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4>Nöbet Yönetimi</h4>
                </div>
                <div class="card-body">
                    <p>Nöbet saatlerini ve ilgili personel ayarlarını yönetebilirsiniz.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h4>Randevu Yönetimi</h4>
                </div>
                <div class="card-body">
                    <p>Randevuların oluşturulması, düzenlenmesi ve iptali işlemlerini buradan gerçekleştirin.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h4>Personel Bilgi Yönetimi</h4>
                </div>
                <div class="card-body">
                    <p>Personel bilgilerini görüntüleyin ve düzenleyin.</p>
                </div>
            </div>
        </div>
    </div>
</div>


