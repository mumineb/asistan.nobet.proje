@model IEnumerable<PediatriAsistanNöbet1.Models.Model.Musaitlik>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th>@Html.DisplayNameFor(model => model.OgretimUyesi.Ad)</th>
        <th>@Html.DisplayNameFor(model => model.Tarih)</th>
        <th>@Html.DisplayNameFor(model => model.Saat)</th>

        <th></th>
    </tr>
    @foreach (var item in Model)
    {
        <tr>
            <td>@(item.OgretimUyesi.Ad + " " + item.OgretimUyesi.Soyad)</td>
            <td>@Html.DisplayFor(modelItem => item.Tarih)</td>
            <td>@Html.DisplayFor(modelItem => item.Saat)</td>
            
            <td>
                @Html.ActionLink("Edit", "Edit", new { id = item.MusaitlikID }) |
                @Html.ActionLink("Delete", "Delete", new { id = item.MusaitlikID })
            </td>
        </tr>
    }
</table>

