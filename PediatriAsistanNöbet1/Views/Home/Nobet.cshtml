
@{
    ViewBag.Title = "Nobet";
    Layout = "~/Views/Shared/_SiteLayout.cshtml";
}

<h2>Nöbet Takvim</h2>


<!DOCTYPE html>
<html>
<head>
    <meta charset='utf-8' />
    <script src="~/Content/fullcalendar/dist/index.global.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');
            var calendar = new FullCalendar.Calendar(calendarEl, {
                headerToolbar: {
                    left: 'prevYear,prev,next,nextYear today',
                    center: 'title',
                    right: 'dayGridMonth,dayGridWeek,dayGridDay'
                },
                initialDate: new Date(), // Bugünün tarihi
                navLinks: true, // Haftalık ve günlük görünümler için tıklanabilir
                editable: false,
                dayMaxEvents: true,
                events: function (info, successCallback, failureCallback) {
                    $.ajax({
                        url: '/Home/GetNobetler', // JSON verisini sağlayan metot
                        type: 'GET',
                        success: function (data) {
                            // Veriyi FullCalendar için uygun formata dönüştürme
                            successCallback(data); // Dönüştürülmüş veriyi FullCalendar'a gönderiyoruz
                        },
                        error: function () {
                            failureCallback(); // Hata durumunda
                        }
                    });
                },
                    eventTimeFormat: { // Saat formatını kaldırma
                    hour: '2-digit',
                    minute: '2-digit',
                    meridiem: false // AM/PM'yi kaldır
                },
                eventRender: function (info) {
                    // Etkinlik başlığında saat kısmını kaldırıyoruz
                    var eventTitle = info.event.title.split(' - ')[0]; // sadece isim kısmını alıyoruz
                    info.el.querySelector('.fc-event-title').innerText = eventTitle;
                }

            });

            calendar.render();
        });



    </script>
    <style>
        body {
            margin: 40px 10px;
            padding: 0;
            font-family: Arial, Helvetica Neue, Helvetica, sans-serif;
            font-size: 14px;
        }

        #calendar {
            max-width: 1100px;
            margin: 0 auto;
        }

        .fc-event-title {
            white-space: normal !important;
            word-wrap: break-word !important;
        }

    </style>
</head>
<body>

    <div id='calendar'></div>

</body>
</html>

